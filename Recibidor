        <?php
        // Verificar si se enviaron datos por POST
        if ($_SERVER["REQUEST_METHOD"] == "POST") {
            
            // Recibir y limpiar los datos (evitar inyección XSS)
            $nombre = isset($_POST['Nombre']) ? htmlspecialchars($_POST['Nombre']) : "No proporcionado";
            $correo = isset($_POST['Correo']) ? htmlspecialchars($_POST['Correo']) : "No proporcionado";
            $pais = isset($_POST['paises']) ? htmlspecialchars($_POST['paises']) : "No seleccionado";
            $genero = isset($_POST['genero']) ? htmlspecialchars($_POST['genero']) : "No seleccionado";
            $aceptar = isset($_POST['aceptar']) ? "Sí" : "No";
            $comentario = isset($_POST['comentario']) ? htmlspecialchars($_POST['comentario']) : "Sin comentarios";
            
            // Mostrar los datos
            echo "<div class='dato'>";
            echo "<span class='etiqueta'>👤 Nombre:</span> " . $nombre . "<br>";
            echo "</div>";
            
            echo "<div class='dato'>";
            echo "<span class='etiqueta'>📧 Correo:</span> " . $correo . "<br>";
            echo "</div>";
            
            echo "<div class='dato'>";
            echo "<span class='etiqueta'>🌍 País:</span> ";
            // Mostrar nombre del país en lugar del código
            switch($pais) {
                case "sv": echo "El Salvador"; break;
                case "mx": echo "México"; break;
                case "fr": echo "Francia"; break;
                default: echo $pais;
            }
            echo "<br>";
            echo "</div>";
            
            echo "<div class='dato'>";
            echo "<span class='etiqueta'>⚥ Género:</span> " . $genero . "<br>";
            echo "</div>";
            
            echo "<div class='dato'>";
            echo "<span class='etiqueta'>✅ Acepta términos:</span> " . $aceptar . "<br>";
            echo "</div>";
            
            echo "<div class='dato'>";
            echo "<span class='etiqueta'>💬 Comentarios:</span><br>";
            echo nl2br($comentario);  // nl2br convierte saltos de línea a <br>
            echo "</div>";
            
            // Mostrar todos los datos recibidos (para depuración)
            echo "<hr>";
            echo "<details>";
            echo "<summary>🔧 Ver todos los datos crudos (para depuración)</summary>";
            echo "<pre>";
            print_r($_POST);
            echo "</pre>";
            echo "</details>";
            
        } else {
            echo "<div class='error'>";
            echo "❌ Error: No se recibieron datos. Asegúrate de enviar el formulario correctamente.";
            echo "</div>";
            echo "<br>";
            echo "<a href='tu_formulario.html'>← Volver al formulario</a>";
        }
        ?>
        
